  // E/I: 外向(+) vs 内向(-)
  // S/N: 現実(+) vs 直感(-)
  // T/F: 論理(+) vs 感情(-)
  // J/P: 計画(+) vs 柔軟(-)
  let ei=0,sn=0,tf=0,jp=0;

  // Q01 テンション上がる瞬間
  const q01=ans['q01'];
  if(q01===0){ei+=2;sn-=1;tf-=2;}      // 誰かが変わった瞬間 → E,F
  else if(q01===1){ei+=2;tf+=1;jp+=2;} // チーム目標達成 → E,T,J
  else if(q01===2){ei-=1;sn+=2;tf+=1;} // アイデアが形に → N,T
  else if(q01===3){ei+=2;tf-=2;}       // 仲間と本音 → E,F
  else if(q01===4){ei-=1;tf+=2;jp+=1;} // 自分の数字 → I,T,J

  // Q02 3年後ビジョン
  const q02=ans['q02'];
  if(q02===0){ei-=1;sn-=1;jp+=1;}      // プロとして独り立ち → I,S,J
  else if(q02===1){ei+=2;tf+=1;jp+=2;} // マネジメント → E,T,J
  else if(q02===2){ei-=1;sn-=1;tf-=1;jp+=1;} // 組織内側 → I,S,F,J
  else if(q02===3){ei+=1;sn+=2;tf+=1;jp-=2;} // 発信・成長 → E,N,T,P
  else if(q02===4){ei-=1;sn+=2;jp-=2;} // 独立 → I,N,P

  // Q03 強み
  const q03=ans['q03'];
  if(q03===0){ei+=2;tf-=2;}            // 信頼関係 → E,F
  else if(q03===1){ei+=1;tf-=2;}       // 安心感 → E,F
  else if(q03===2){ei+=1;sn-=1;jp-=1;} // 実行力 → E,S,P
  else if(q03===3){ei-=1;tf-=2;jp+=1;} // 教える → I,F,J
  else if(q03===4){ei-=2;sn+=2;tf+=2;jp+=1;} // 構造設計 → I,N,T,J

  // Q05 感情コントロール
  const q05=ans['q05'];
  if(q05===0){tf+=1;jp+=1;}
  else if(q05===1){tf+=1;}
  else if(q05===2){tf+=2;jp+=2;}
  else if(q05===3){tf-=1;}
  else if(q05===4){tf-=2;ei+=1;}      // 感情が出やすい → F,E

  // Q06 弱音を吐ける
  const q06=ans['q06'];
  if(q06===0){ei+=1;tf-=1;}
  else if(q06===1){tf-=2;}            // 関係が深まる → F
  else if(q06===2){ei-=1;}
  else if(q06===3){ei+=1;tf+=2;jp-=1;} // 行動で乗り越える → E,T,P
  else if(q06===4){ei-=2;tf+=1;}      // 自分の中で処理 → I,T

  // Q07 給与上がらない時期
  const q07=ans['q07'];
  if(q07===0){sn+=1;tf-=1;jp+=1;}
  else if(q07===1){ei+=1;tf-=1;}
  else if(q07===2){sn-=1;tf-=1;}
  else if(q07===3){jp+=1;}
  else if(q07===4){tf+=2;sn-=1;}     // 数字が出れば → T,S

  // Q08 お客様との関係
  const q08=ans['q08'];
  if(q08===0){tf-=2;sn-=1;}          // 長く続く信頼 → F,S
  else if(q08===1){tf-=1;sn+=1;}     // 人生に役立つ → F,N
  else if(q08===2){tf-=2;ei+=1;}     // 安心感 → F,E
  else if(q08===3){tf+=1;jp+=1;}     // 期待以上の結果 → T,J
  else if(q08===4){tf+=2;sn-=1;jp+=1;} // 効率よく → T,S,J

  // Q09 輝ける場面
  const q09=ans['q09'];
  if(q09===0){ei-=1;tf-=2;}          // 一対一 → I,F
  else if(q09===1){ei+=2;tf+=1;jp+=1;} // チームを引っ張る → E,T,J
  else if(q09===2){sn+=2;tf+=1;jp-=1;} // アイデア実現 → N,T,P
  else if(q09===3){ei+=1;tf-=2;}     // ありがとう → E,F
  else if(q09===4){sn-=1;jp+=2;}     // 積み上げが結実 → S,J

  // Q11 業界への興味
  const q11=ans['q11'];
  if(q11===0){tf-=1;sn+=1;}          // 変化・成長に関わる → F,N
  else if(q11===1){sn-=2;tf-=1;}     // 体・健康への関心 → S,F
  else if(q11===2){tf-=1;}
  else if(q11===3){tf+=1;sn+=1;}     // ビジネス的成長 → T,N
  else if(q11===4){ei+=1;}

  // Q12 3年後どんな自分
  const q12=ans['q12'];
  if(q12===0){ei+=1;tf+=1;jp+=2;}    // マネジメント → E,T,J
  else if(q12===1){ei-=1;sn-=2;jp+=1;} // プロ独り立ち → I,S,J
  else if(q12===2){sn+=1;tf+=2;jp+=1;} // 幹部候補 → N,T,J
  else if(q12===3){ei-=1;tf-=1;jp+=1;} // 組織内側 → I,F,J
  else if(q12===4){sn+=2;jp-=2;}     // 独立 → N,P

  // Q13 強み
  const q13=ans['q13'];
  if(q13===0){ei+=1;tf-=2;}          // 空気をつくる → E,F
  else if(q13===1){ei-=1;sn-=1;jp-=1;} // 実行力 → I,S,P
  else if(q13===2){tf-=1;jp+=1;}     // 教える → F,J
  else if(q13===3){ei+=2;tf-=2;}     // 信頼関係 → E,F
  else if(q13===4){ei-=2;sn+=2;tf+=2;jp+=1;} // 論理設計 → I,N,T,J

  // Q14 長期的に大切にしたいこと
  const q14=ans['q14'];
  if(q14===0){tf-=1;sn-=1;}          // お客様に深く → F,S
  else if(q14===1){ei+=1;tf-=1;jp+=1;} // 組織・後輩 → E,F,J
  else if(q14===2){ei+=1;tf+=1;jp+=2;} // 会社と成長 → E,T,J
  else if(q14===3){jp+=1;}
  else if(q14===4){jp-=1;}           // ライフスタイル → P

  // ── 4文字決定 ──
  const E = ei>=0 ? 'E' : 'I';
  const S = sn<=0 ? 'S' : 'N';
  const T = tf>=0 ? 'T' : 'F';
  const J = jp>=0 ? 'J' : 'P';
  const mbti = E+S+T+J;

  // ── IQ域推定（思考スタイル軸から） ──
  let iqScore = 0;
  // 構造・論理・設計系の選択で加点
  if(ans['q03']===4) iqScore+=20; // 構造設計が強み
  if(ans['q13']===4) iqScore+=20; // 論理設計
  if(ans['q12']===2) iqScore+=10; // 幹部候補志向
  if(ans['q07']===0) iqScore+=10; // 投資期間と割り切れる
  if(ans['q01']===2) iqScore+=10; // アイデア実現でテンション
  if(ans['q09']===2) iqScore+=10; // アイデアを形に
  if(ans['q02']===3) iqScore+=10; // 戦略・発信志向
  if(ans['q11']===2) iqScore+=5;  // ビジネス的成長

  let iqRange, iqNote;
  if(iqScore>=50){ iqRange='115〜130'; iqNote='分析・構造把握型'; }
  else if(iqScore>=30){ iqRange='105〜120'; iqNote='バランス知性型'; }
  else if(iqScore>=15){ iqRange='95〜110'; iqNote='実践・対人知性型'; }
  else{ iqRange='90〜105'; iqNote='感性・直感型'; }

  // ── EQ評価（対人感受性・感情管理軸から） ──
  let eqScore = 0;
  if(ans['q01']===0) eqScore+=15; // 誰かの変化に立ち会える
  if(ans['q01']===3) eqScore+=10; // 仲間と本音
  if(ans['q03']===0||ans['q03']===1) eqScore+=15; // 信頼・安心感
  if(ans['q03']===2) eqScore+=5;
  if(ans['q05']===0||ans['q05']===1||ans['q05']===2) eqScore+=10; // 感情管理できる
  if(ans['q06']===1) eqScore+=15; // 弱さを見せると関係深まる
  if(ans['q06']===0||ans['q06']===2) eqScore+=10;
  if(ans['q08']===0||ans['q08']===1||ans['q08']===2) eqScore+=15; // 信頼・役立つ・安心
  if(ans['q09']===0||ans['q09']===3) eqScore+=10; // 一対一・ありがとう
  if(ans['q13']===0||ans['q13']===3) eqScore+=10; // 空気・信頼

  let eqGrade, eqNote;
  if(eqScore>=80){ eqGrade='A'; eqNote='対人感受性が非常に高い'; }
  else if(eqScore>=55){ eqGrade='B'; eqNote='バランスのとれた感情知性'; }
  else if(eqScore>=30){ eqGrade='C'; eqNote='論理優位・共感は選択的'; }
  else{ eqGrade='D'; eqNote='タスク思考が強い'; }

  return { mbti, iqRange, iqNote, eqGrade, eqNote };
}


function grade(sc){
  if(sc>=93) return{label:'S+',color:'#b5833a',note:'飛び抜けた適性'};
  if(sc>=80) return{label:'S', color:'#2a8a52',note:'非常に高い適性'};
  if(sc>=65) return{label:'A', color:'#3a7eb5',note:'高い適性'};
  return           {label:'B', color:'#c47a2a',note:'これから開花する'};
}

