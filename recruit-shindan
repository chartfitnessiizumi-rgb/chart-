  document.getElementById('b-start')?.addEventListener('click',()=>{S.phase='info';go();});
  document.getElementById('b-info-next')?.addEventListener('click',()=>{
    const name=document.getElementById('inp-name')?.value.trim();
    if(!name){document.getElementById('name-error').style.display='block';return;}
    S.name=name; S.email=''; S.phase='q'; S.qi=0; go();
