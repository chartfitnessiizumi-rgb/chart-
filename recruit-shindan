const TYPE_LABELS = {W:'ワクワク系', I:'自己分析系', R:'関わり方系'};
const TYPE_STYLES = {W:'qtag-w', I:'qtag-i', R:'qtag-r'};

function normalize(raw,minR,maxR){ return Math.round(48+((Math.min(maxR,Math.max(minR,raw))-minR)/(maxR-minR))*52); }

function calcAll(ans){
  let store=0,area=0,marketing=0,hr=0,trainer=0,match=0;
  QS.forEach(q=>{
    const i=ans[q.id]; if(i===undefined) return;
    const s=q.opts[i].s;
    store+=s[0];area+=s[1];marketing+=s[2];hr+=s[3];trainer+=s[4];match+=s[5];
  });
  const trainerScore=normalize(trainer,0,224);
  const matchScore=normalize(match,0,224);
  const storeScore=normalize(store,0,216);
  const areaScore=normalize(area,0,216);
  const marketingScore=normalize(marketing,0,216);
  const hrScore=normalize(hr,0,216);
  const deptScores={store:storeScore,area:areaScore,marketing:marketingScore,hr:hrScore};
  const deptOrder=Object.entries(deptScores).sort((a,b)=>b[1]-a[1]);
  return{trainer:trainerScore,deptMax:deptOrder[0][1],match:matchScore,deptScores,deptOrder,topDeptId:deptOrder[0][0]};
}

