.btn{font-family:'Noto Sans JP',sans-serif;font-size:13px;font-weight:500;padding:12px 26px;cursor:pointer;border:none;transition:all .15s;letter-spacing:.06em;}
.btn-g{background:transparent;border:1.5px solid var(--border);color:var(--sub);}
